{
  "name": "forms",
  "version": "1.0.0",
  "description": "Forms",
  "main": "./forms.js",
  "scripts": {
    "formbuilder": "webpack --entry ./formbuilder.js --output-path . --output-filename formbuilder.min.js --progress --mode=production --devtool source-map",
    "formtable": "webpack --entry ./forms_table.js --output-path . --output-filename forms_table.min.js --progress --mode=production --devtool source-map",
    "forms": "webpack --config forms.config.js",
    "tinymce": "webpack --entry ./tiny_mce.js --output-path . --output-filename tiny_mce.min.js --progress --mode=production --devtool source-map",
    "formbuilder-watch": "webpack --watch --entry ./formbuilder.js --output-path . --output-filename formbuilder.min.js --progress --mode=production --devtool source-map",
    "formtable-watch": "webpack --watch --entry ./forms_table.js --output-path . --output-filename forms_table.min.js --progress --mode=production --devtool source-map",
    "forms-watch": "webpack --watch --config forms.config.js",
    "tinymce-watch": "webpack --watch --entry ./tiny_mce.js --output-path . --output-filename tiny_mce.min.js --progress --mode=production --devtool source-map",
    "all": "run-p formbuilder formtable forms tinymce",
    "watch-all": "run-p formbuilder-watch formtable-watch forms-watch tinymce-watch"
  },
  "author": "Ewald Harmsen",
  "license": "ISC",
  "devDependencies": {
    "webpack": "^5.107.2",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
